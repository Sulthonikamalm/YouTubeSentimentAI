YOUTUBE_API_KEY=
DATABASE_URL=sqlite:///data/youtube_monitor.db
CRAWL_INTERVAL_MINUTES=10
MAX_COMMENTS_PER_VIDEO_PER_RUN=100
FETCH_REPLIES=true
MAX_REPLIES_PER_COMMENT=100
ENABLE_AUTO_CRAWL=false
YOUTUBE_ORDER=time
YOUTUBE_TEXT_FORMAT=plainText
REQUEST_TIMEOUT_SECONDS=20
QUOTA_DAILY_LIMIT=10000
QUOTA_WARNING_THRESHOLD=8000

# Inference settings
INFERENCE_BATCH_SIZE=500
ENABLE_INFERENCE_AFTER_CRAWL=true

# Ollama (Sahabat-AI) Settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=csalab/sahabatai1:llama3_instruct_Q4_K_M
OLLAMA_TIMEOUT=300

# Gemini Taxonomy AI Settings
ENABLE_GEMINI_TAXONOMY=false
GEMINI_API_KEY=key_1,key_2,key_3
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_GENERATIONS_PER_PROJECT_PER_DAY=3
GEMINI_SAMPLE_LIMIT=100
GEMINI_MIN_SAMPLE_SIZE=20
